<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.ui.controller.EditProjectController">
    <stylesheets>
        <URL value="@../css/app.css"/>
    </stylesheets>

    <VBox styleClass="dialog-card" spacing="14" alignment="TOP_CENTER"
          StackPane.alignment="CENTER">

        <Label text="Modifier le projet" styleClass="page-title"/>

        <TextField fx:id="nameField" styleClass="form-input"
                   promptText="Nom du projet" maxWidth="Infinity"/>
        <TextField fx:id="descriptionField" styleClass="form-input"
                   promptText="Description" maxWidth="Infinity"/>
        <DatePicker fx:id="startDatePicker" styleClass="form-input"
                    promptText="Date début" maxWidth="Infinity"/>
        <DatePicker fx:id="endDatePicker" styleClass="form-input"
                    promptText="Date fin" maxWidth="Infinity"/>

        <Label fx:id="errorLabel" styleClass="error-label"/>

        <Button text="Enregistrer" onAction="#handleSave"
                styleClass="btn-primary" maxWidth="Infinity"/>
    </VBox>

</StackPane>
