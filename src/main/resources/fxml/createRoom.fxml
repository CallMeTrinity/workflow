<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ui.controller.CreateRoomController">

    <Label text="Ajouter une salle"/>

    <TextField fx:id="nameField" promptText="Nom de la salle"/>
    <TextField fx:id="capacityField" promptText="Capacité"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

    <Button text="Valider" onAction="#handleCreate"/>

</VBox>
