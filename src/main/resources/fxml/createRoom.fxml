<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.ui.controller.CreateRoomController">
    <stylesheets>
        <URL value="@../css/app.css"/>
    </stylesheets>

    <VBox styleClass="dialog-card" spacing="14" alignment="TOP_CENTER"
          StackPane.alignment="CENTER">

        <Label text="Ajouter une salle" styleClass="page-title"/>

        <TextField fx:id="nameField" styleClass="form-input"
                   promptText="Nom de la salle" maxWidth="Infinity"/>
        <TextField fx:id="capacityField" styleClass="form-input"
                   promptText="Capacité" maxWidth="Infinity"/>

        <Label fx:id="errorLabel" styleClass="error-label"/>

        <Button text="Valider" onAction="#handleCreate"
                styleClass="btn-primary" maxWidth="Infinity"/>
    </VBox>

</StackPane>
