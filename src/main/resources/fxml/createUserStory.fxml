<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.ui.controller.CreateUserStoryController"
            fitToWidth="true" fitToHeight="true"
            styleClass="modal-scroll">
    <stylesheets>
        <URL value="@../css/app.css"/>
    </stylesheets>

    <VBox styleClass="dialog-card" spacing="14" alignment="TOP_CENTER"
          style="-fx-max-width: 460;">

        <Label fx:id="formTitle" text="Créer une User Story" styleClass="page-title"/>

        <TextField fx:id="titleField" styleClass="form-input"
                   promptText="Titre" maxWidth="Infinity"/>
        <TextArea fx:id="descriptionField" styleClass="form-input"
                  promptText="Description" maxWidth="Infinity" prefRowCount="4"/>

        <ComboBox fx:id="priorityBox" styleClass="form-input"
                  promptText="Priorité" maxWidth="Infinity"/>

        <Label fx:id="errorLabel" styleClass="error-label"/>

        <Button fx:id="submitButton" text="Créer" onAction="#handleCreate"
                styleClass="btn-primary" maxWidth="Infinity"/>
    </VBox>

</ScrollPane>
