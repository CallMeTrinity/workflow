<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.ui.controller.EditReservationController"
            fitToWidth="true" fitToHeight="true"
            styleClass="modal-scroll">
    <stylesheets>
        <URL value="@../css/app.css"/>
    </stylesheets>

    <VBox styleClass="dialog-card" spacing="14" alignment="TOP_CENTER"
          style="-fx-max-width: 520; -fx-pref-width: 500;">

        <Label text="Détail de la réservation" styleClass="page-title"/>

        <Label fx:id="organizerLabel" styleClass="cal-event-detail" style="-fx-font-size: 13px;"/>

        <TextField fx:id="titleField" styleClass="form-input"
                   promptText="Titre" maxWidth="Infinity"/>
        <TextField fx:id="descriptionField" styleClass="form-input"
                   promptText="Description" maxWidth="Infinity"/>

        <DatePicker fx:id="datePicker" styleClass="form-input" maxWidth="Infinity"
                    promptText="Date"/>
        <HBox spacing="10">
            <ComboBox fx:id="startTimeBox" styleClass="form-input" HBox.hgrow="ALWAYS"
                      maxWidth="Infinity" minWidth="120" promptText="Heure début"/>
            <ComboBox fx:id="endTimeBox" styleClass="form-input" HBox.hgrow="ALWAYS"
                      maxWidth="Infinity" minWidth="120" promptText="Heure fin"/>
        </HBox>

        <ComboBox fx:id="roomBox" styleClass="form-input" maxWidth="Infinity"
                  promptText="Salle"/>

        <Label text="Participants" styleClass="section-title"/>
        <FlowPane fx:id="participantChips" hgap="6" vgap="6" maxWidth="Infinity"/>
        <ComboBox fx:id="addParticipantBox" styleClass="form-input" maxWidth="Infinity"
                  promptText="Ajouter un participant..."/>

        <Label fx:id="errorLabel" styleClass="error-label"/>

        <Button text="Enregistrer" onAction="#handleSave"
                styleClass="btn-primary" maxWidth="Infinity"/>
    </VBox>

</ScrollPane>
