<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.ui.controller.CreateReservationController"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: #f5f7fa;">
    <stylesheets>
        <URL value="@../css/app.css"/>
    </stylesheets>

    <VBox styleClass="dialog-card" spacing="14" alignment="TOP_CENTER"
          style="-fx-max-width: 460;">

        <Label text="Nouvelle réservation" styleClass="page-title"/>

        <TextField fx:id="titleField" styleClass="form-input"
                   promptText="Titre" maxWidth="Infinity"/>
        <TextField fx:id="descriptionField" styleClass="form-input"
                   promptText="Description" maxWidth="Infinity"/>
        <DatePicker fx:id="datePicker" styleClass="form-input"
                    promptText="Date" maxWidth="Infinity"/>
        <ComboBox fx:id="startTimeBox" styleClass="form-input"
                  promptText="Heure début" maxWidth="Infinity"/>
        <ComboBox fx:id="endTimeBox" styleClass="form-input"
                  promptText="Heure fin" maxWidth="Infinity"/>
        <ComboBox fx:id="roomBox" styleClass="form-input"
                  promptText="Sélectionner une salle" maxWidth="Infinity"/>

        <Label fx:id="errorLabel" styleClass="error-label"/>

        <Button text="Valider" onAction="#handleCreate"
                styleClass="btn-primary" maxWidth="Infinity"/>
    </VBox>

</ScrollPane>
