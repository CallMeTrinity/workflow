<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ui.controller.KanbanController">

    <HBox spacing="10" alignment="CENTER_LEFT">

        <!-- gauche -->
        <Button text="Retour" onAction="#goBackToDashboard"/>
        <Button text="Ajouter une tâche" onAction="#handleAddTask"/>

        <!-- pousse à droite -->
        <Region HBox.hgrow="ALWAYS"/>

        <!-- droite -->
        <HBox spacing="15" alignment="CENTER_RIGHT">

            <VBox spacing="2">
                <Label text="Filtrer"/>
                <ComboBox fx:id="filterPriorityBox"
                          style="
              -fx-background-color: white;
              -fx-border-color: #cccccc;
              -fx-border-radius: 8;
              -fx-background-radius: 8;
              -fx-padding: 3 8 3 8;
          "/>
            </VBox>

            <VBox spacing="2">
                <Label text="Trier"/>
                <ComboBox fx:id="sortBox"
                          style="
              -fx-background-color: white;
              -fx-border-color: #cccccc;
              -fx-border-radius: 8;
              -fx-background-radius: 8;
              -fx-padding: 3 8 3 8;
          "/>
            </VBox>

        </HBox>

    </HBox>

    <HBox spacing="20"
          alignment="CENTER"
          VBox.vgrow="ALWAYS"
          style="-fx-padding: 20 40 20 40;">
        <VBox fx:id="todoColumn" spacing="5" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="A FAIRE" style="-fx-font-weight: bold;"/>
            <ListView fx:id="todoList" VBox.vgrow="ALWAYS"/>
        </VBox>
        <VBox fx:id="inProgressColumn" spacing="5" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="EN COURS" style="-fx-font-weight: bold;"/>
            <ListView fx:id="inProgressList" VBox.vgrow="ALWAYS"/>
        </VBox>
        <VBox fx:id="doneColumn" spacing="5" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="TERMINE" style="-fx-font-weight: bold;"/>
            <ListView fx:id="doneList" VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>


</VBox>
