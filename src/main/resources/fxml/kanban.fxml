<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ui.controller.KanbanController">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Retour" onAction="#goBackToDashboard"/>
        <Button text="Ajouter une tâche" onAction="#handleAddTask"/>
    </HBox>

    <HBox spacing="20" alignment="CENTER" VBox.vgrow="ALWAYS">
        <VBox fx:id="todoColumn" spacing="5" HBox.hgrow="ALWAYS">
            <Label text="TODO"/>
            <ListView fx:id="todoList" VBox.vgrow="ALWAYS"/>
        </VBox>
        <VBox fx:id="inProgressColumn" spacing="5" HBox.hgrow="ALWAYS">
            <Label text="IN PROGRESS"/>
            <ListView fx:id="inProgressList" VBox.vgrow="ALWAYS"/>
        </VBox>
        <VBox fx:id="doneColumn" spacing="5" HBox.hgrow="ALWAYS">
            <Label text="DONE"/>
            <ListView fx:id="doneList" VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>

</VBox>
