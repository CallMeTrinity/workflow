<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<VBox spacing="0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ui.controller.KanbanController">

    <!-- Topbar : navigation + action principale -->
    <HBox styleClass="topbar" spacing="12" alignment="CENTER_LEFT">
        <ImageView fitHeight="28" fitWidth="28" preserveRatio="true">
            <image><Image url="@../images/workflow_logo.png"/></image>
        </ImageView>
        <Button text="← Retour" onAction="#goBackToDashboard" styleClass="btn-back"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Tâche" onAction="#handleAddTask" styleClass="btn-primary"/>
    </HBox>

    <!-- Barre d'outils : gestion projet + filtres -->
    <HBox styleClass="kanban-toolbar" spacing="10" alignment="CENTER_LEFT">
        <Button text="User Stories" onAction="#handleOpenUserStories" styleClass="btn-back"/>
        <Button text="Membres"      onAction="#handleOpenMembers"      styleClass="btn-back"/>
        <Separator orientation="VERTICAL" style="-fx-padding: 0 4 0 4;"/>
        <ToggleButton fx:id="myTasksBtn" text="Mes tâches" onAction="#loadTasks" styleClass="toggle-switch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="🔍 Rechercher une tâche…"
                   styleClass="form-input, search-field" prefWidth="220"/>
        <Label text="User Story :" styleClass="muted-label"/>
        <ComboBox fx:id="filterUserStoryBox" prefWidth="150"/>
        <Label text="Priorité :" styleClass="muted-label"/>
        <ComboBox fx:id="filterPriorityBox" prefWidth="120"/>
        <Label text="Tri :" styleClass="muted-label"/>
        <ComboBox fx:id="sortBox" prefWidth="130"/>
    </HBox>

    <!-- Colonnes kanban -->
    <HBox spacing="16" alignment="TOP_CENTER" VBox.vgrow="ALWAYS"
          style="-fx-padding: 20 24 20 24;">

        <VBox fx:id="todoColumn" styleClass="kanban-column" spacing="8"
              alignment="CENTER" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="À FAIRE" styleClass="kanban-header"/>
                <Label fx:id="todoCountLabel" text="0" styleClass="kanban-count"/>
            </HBox>
            <ListView fx:id="todoList" styleClass="kanban-list" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox fx:id="inProgressColumn" styleClass="kanban-column" spacing="8"
              alignment="CENTER" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="EN COURS" styleClass="kanban-header"/>
                <Label fx:id="inProgressCountLabel" text="0" styleClass="kanban-count"/>
            </HBox>
            <ListView fx:id="inProgressList" styleClass="kanban-list" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox fx:id="doneColumn" styleClass="kanban-column" spacing="8"
              alignment="CENTER" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="TERMINÉ" styleClass="kanban-header"/>
                <Label fx:id="doneCountLabel" text="0" styleClass="kanban-count"/>
            </HBox>
            <ListView fx:id="doneList" styleClass="kanban-list" VBox.vgrow="ALWAYS"/>
        </VBox>

    </HBox>

</VBox>
