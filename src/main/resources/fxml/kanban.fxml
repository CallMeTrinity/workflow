<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ui.controller.KanbanController">

    <!-- 🔹 Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button text="← Retour" onAction="#handleBack"/>
        <Label text="Kanban"/>
    </HBox>

    <!-- 🔹 Colonnes -->
    <HBox spacing="20">

        <VBox>
            <Label text="TODO"/>
            <ListView fx:id="todoList" onMouseClicked="#handleTodoClick"/>
        </VBox>

        <VBox>
            <Label text="IN PROGRESS"/>
            <ListView fx:id="inProgressList" onMouseClicked="#handleInProgressClick"/>
        </VBox>

        <VBox>
            <Label text="DONE"/>
            <ListView fx:id="doneList" onMouseClicked="#handleDoneClick"/>
        </VBox>

        <Button text="+ Ajouter tâche" onAction="#handleAddTask"/>

    </HBox>

</VBox>