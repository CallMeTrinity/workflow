<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.ui.controller.ProfileController">

    <left>
        <VBox spacing="15" alignment="CENTER" prefWidth="250">

            <Label text="Profil" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <StackPane>
                <Circle fx:id="avatarCircle" radius="40"/>
                <Label fx:id="avatarLabel"
                       style="-fx-text-fill: white; -fx-font-size: 24px;"/>
            </StackPane>

            <TextField fx:id="pseudoField" promptText="Pseudo"/>
            <TextField fx:id="emailField" editable="false" style="-fx-opacity: 0.6;"/>
            <TextField fx:id="roleField" editable="false" style="-fx-opacity: 0.6;"/>

        </VBox>
    </left>

    <center>
        <VBox spacing="10" style="-fx-padding: 20;">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Notifications" style="-fx-font-size: 18px;"/>
                <Button text="Tout marquer comme lu"
                        onAction="#markAllAsRead"/>
            </HBox>

            <ListView fx:id="notificationList"/>

        </VBox>
    </center>

</BorderPane>